{
  "name": "@imaginerlabs/comfyui-agent-helper",
  "version": "1.0.0",
  "description": "面向 AI Agent 的 ComfyUI 工作流分步构建库，将工作流拆分为可独立设计的 Step 区块",
  "keywords": [
    "comfyui",
    "workflow",
    "ai-agent",
    "stable-diffusion",
    "node-graph"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ImaginerLabs/ComfyUI-Agent-Helper.git"
  },
  "bugs": {
    "url": "https://github.com/ImaginerLabs/ComfyUI-Agent-Helper/issues"
  },
  "homepage": "https://github.com/ImaginerLabs/ComfyUI-Agent-Helper#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "eslint": "10.3.0",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "4.1.5"
  }
}
